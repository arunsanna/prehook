class Prehook < Formula
  desc "Local Git hook security gates"
  homepage "https://github.com/__OWNER__/__REPO__"
  url "https://github.com/__OWNER__/__REPO__/archive/refs/tags/v__VERSION__.tar.gz"
  sha256 "__SHA256__"
  version "__VERSION__"
  license "MIT"

  depends_on "go" => :build
  depends_on "gitleaks"
  depends_on "trufflehog"
  depends_on "semgrep"
  depends_on "osv-scanner"
  depends_on "trivy"

  def install
    ldflags = "-s -w -X main.version=#{version}"
    system "go", "build", *std_go_args(ldflags:), "."
  end

  test do
    assert_match "prehook", shell_output("#{bin}/prehook version")
  end
end
